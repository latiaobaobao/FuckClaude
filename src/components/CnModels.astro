---
/**
 * "模型还是中国的好" promo for domestic LLMs (DeepSeek / GLM / Kimi).
 *
 * Wide viewports (>=1500px and tall enough): two fixed rails pinned to the
 * left / right edges of the page, vertically centered, styled like Spring
 * Festival couplet scrolls (red + gold).
 * Narrower viewports: the rails hide and an inline strip below the hero
 * shows the same cards instead.
 *
 * Outbound clicks are tagged for GA via data-ga-* (see src/scripts/track.ts).
 */
import { useTranslations, type Lang } from '../i18n/ui';
import { CN_MODELS } from '../config/cn-models';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const rails = [
  { side: 'left', models: CN_MODELS.filter((m) => m.side === 'left') },
  { side: 'right', models: CN_MODELS.filter((m) => m.side === 'right') },
];
---

{
  rails.map(({ side, models }) => (
    <aside class={`cn-rail cn-rail--${side}`} aria-label={t('cnModels.label')}>
      <p class="cn-slogan">{t('cnModels.slogan')}</p>
      {models.map((m) => (
        <a
          class="cn-card"
          href={m.url}
          target="_blank"
          rel="noopener noreferrer"
          data-ga-event="cn_model_click"
          data-ga-id={m.id}
        >
          <img
            class="cn-card__img"
            src={m.img}
            width={m.imgWidth}
            height={m.imgHeight}
            alt={m.name}
            loading="lazy"
            decoding="async"
          />
          <span class="cn-card__name">{m.name}</span>
          <span class="cn-card__tagline">{m.tagline[lang]}</span>
          <span class="cn-card__cta">
            {t('cnModels.cta')}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14" />
              <path d="m13 6 6 6-6 6" />
            </svg>
          </span>
        </a>
      ))}
    </aside>
  ))
}

<section class="cn-inline" aria-label={t('cnModels.label')}>
  <p class="cn-slogan cn-inline__slogan">{t('cnModels.slogan')}</p>
  <div class="cn-inline__cards">
    {
      CN_MODELS.map((m) => (
        <a
          class="cn-card"
          href={m.url}
          target="_blank"
          rel="noopener noreferrer"
          data-ga-event="cn_model_click"
          data-ga-id={m.id}
        >
          <img
            class="cn-card__img"
            src={m.img}
            width={m.imgWidth}
            height={m.imgHeight}
            alt={m.name}
            loading="lazy"
            decoding="async"
          />
          <span class="cn-card__name">{m.name}</span>
          <span class="cn-card__tagline">{m.tagline[lang]}</span>
          <span class="cn-card__cta">
            {t('cnModels.cta')}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14" />
              <path d="m13 6 6 6-6 6" />
            </svg>
          </span>
        </a>
      ))
    }
  </div>
</section>

<style>
  /* ---------- shared slogan ribbon (matches the hero "credit" pill) ---------- */
  .cn-slogan {
    margin: 0;
    text-align: center;
    font-family: var(--serif);
    font-weight: 700;
    font-size: 0.92rem;
    letter-spacing: 0.06em;
    color: var(--accent-strong);
    background: var(--surface);
    border: 1px solid color-mix(in srgb, var(--accent) 35%, var(--border));
    border-radius: 999px;
    padding: 7px 14px;
    box-shadow: var(--shadow-sm);
  }

  /* ---------- model card ---------- */
  .cn-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 3px;
    padding: 14px 12px 12px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-sm);
    color: var(--text);
    transition:
      transform 0.18s,
      border-color 0.18s,
      box-shadow 0.18s;
  }
  .cn-card:hover {
    text-decoration: none;
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--accent) 55%, var(--border));
    box-shadow: var(--shadow-md);
  }
  .cn-card__img {
    height: 108px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    transition: transform 0.18s;
  }
  .cn-card:hover .cn-card__img {
    transform: scale(1.06) rotate(-2deg);
  }
  .cn-card__name {
    margin-top: 5px;
    font-weight: 700;
    font-size: 0.98rem;
  }
  .cn-card__tagline {
    font-size: 0.76rem;
    line-height: 1.4;
    color: var(--muted);
  }
  .cn-card__cta {
    margin-top: 8px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 4px 13px;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent-strong);
    font-size: 0.76rem;
    font-weight: 650;
    transition:
      background 0.2s,
      color 0.2s;
  }
  .cn-card:hover .cn-card__cta {
    background: var(--accent);
    color: #fff;
  }
  .cn-card__cta svg {
    width: 11px;
    height: 11px;
  }

  /* ---------- fixed side rails (wide screens) ---------- */
  .cn-rail {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 176px;
    display: none;
    flex-direction: column;
    gap: 12px;
  }
  .cn-rail--left {
    left: 18px;
  }
  .cn-rail--right {
    right: 18px;
  }

  /* ---------- inline strip (narrow screens) ---------- */
  .cn-inline {
    padding: 26px 0 0;
  }
  .cn-inline__slogan {
    width: fit-content;
    margin: 0 auto 14px;
    padding-inline: 22px;
  }
  .cn-inline__cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }

  @media (min-width: 1500px) and (min-height: 680px) {
    .cn-rail {
      display: flex;
    }
    .cn-inline {
      display: none;
    }
  }

  /* phones: switch cards to a compact horizontal layout */
  @media (max-width: 640px) {
    .cn-inline__cards {
      grid-template-columns: 1fr;
      gap: 10px;
    }
    .cn-inline .cn-card {
      display: grid;
      grid-template-areas:
        'img name cta'
        'img tagline cta';
      grid-template-columns: auto 1fr auto;
      align-items: center;
      column-gap: 12px;
      row-gap: 2px;
      text-align: left;
      padding: 10px 12px;
    }
    .cn-inline .cn-card__img {
      grid-area: img;
      height: 64px;
    }
    .cn-inline .cn-card__name {
      grid-area: name;
      margin-top: 0;
      align-self: end;
    }
    .cn-inline .cn-card__tagline {
      grid-area: tagline;
      align-self: start;
    }
    .cn-inline .cn-card__cta {
      grid-area: cta;
      margin-top: 0;
    }
  }
</style>
